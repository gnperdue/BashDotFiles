
# gcloud
export PATH=/opt/homebrew/share/google-cloud-sdk/bin:"$PATH"

alias py3basic="setupminiconda3 && conda activate py3basic"        # Jupyter, IPython
alias py3datsci="setupminiconda3 && conda activate py3datsci"      # Some data sciencey stuff
alias py3qualtran="setupminiconda3 && conda activate py3qualtran"  # Qultran, deps, some scientific Python
alias py3stim="setupminiconda3 && conda activate py3stim"          # Stim, some scientific Python

# set up claude code and uv
export PATH="$HOME/.local/bin:$PATH"
export CLAUDE_CODE_MAX_OUTPUT_TOKENS=64000
export CLAUDE_CODE_EFFORT_LEVEL=max
export CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING=1

# more gcloud
export CLOUDSDK_PYTHON="$(uv python find 3.12)"

# set up node js
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
