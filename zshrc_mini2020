# ~/.zshrc
autoload -Uz compinit
compinit -i

# SDAI
export SDAI_REPOS_BASE_DIR="$HOME/Dropbox/Programming/SDAI/AgentsWork"

# rust
export PATH="$HOME/.cargo/bin:$PATH"

alias py3j="setupminiconda3 && conda activate py3j"
alias py3hf="setupminiconda3 && conda activate py3hf"
alias py3cirq="setupminiconda3 && conda activate py3cirq"
alias py3qec="setupminiconda3 && conda activate py3trch"

# set up Antigravity
export PATH="/Users/perdue/.antigravity/antigravity/bin:$PATH"

# set up claude code
export PATH="$HOME/.local/bin:$PATH"
export CLAUDE_CODE_MAX_OUTPUT_TOKENS=64000
export CLAUDE_CODE_EFFORT_LEVEL=max
export CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING=1

# set up node js
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
